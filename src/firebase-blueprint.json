{
  "entities": {
    "ProjectTask": {
      "title": "ProjectTask",
      "description": "A unified project or task item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "priority": { "type": "string", "enum": ["Low", "Medium", "High"] },
        "status": { "type": "string", "enum": ["Pending", "In Progress", "Completed"] },
        "deadline": { "type": "string" },
        "progress": { "type": "number" },
        "teamMembers": { "type": "array", "items": { "type": "string" } },
        "files": { "type": "array", "items": { "type": "string" } },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "status", "userId"]
    },
    "Payment": {
      "title": "Payment",
      "description": "A payment record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "clientName": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["Pending", "Paid"] },
        "date": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["clientName", "amount", "status", "userId"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "dob": { "type": "string" },
        "email": { "type": "string" },
        "photoUrl": { "type": "string" }
      },
      "required": ["email"]
    }
  },
  "firestore": {
    "/tasks/{taskId}": {
      "schema": "ProjectTask",
      "description": "Collection of projects and tasks"
    },
    "/payments/{paymentId}": {
      "schema": "Payment",
      "description": "Collection of payment records"
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile data"
    }
  }
}
